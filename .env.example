# Copy to .env.local and fill in.
# Get values from Supabase dashboard → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — REQUIRED ONLY for `npm run import`.
# Bypasses RLS. Never commit this. Never ship to the browser.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Telegram bot — get token from @BotFather
TELEGRAM_BOT_TOKEN=
# Random string used to verify webhook calls from Telegram
TELEGRAM_WEBHOOK_SECRET=

# OpenAI — for Whisper voice transcription
OPENAI_API_KEY=

# Anthropic — for Claude API task parsing
ANTHROPIC_API_KEY=

# Resend — for email notifications
RESEND_API_KEY=
# Optional: custom from address (default: onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=

# Vercel Cron — auto-set by Vercel on Hobby+ plans, or set manually
CRON_SECRET=
